/**
 * FileZen — Pipeline CONFIG (Infrastructure as Code)
 * Configure automatiquement la VM de déploiement via Ansible
 *
 * Ce pipeline installe et configure :
 *   - Paquets système (curl, git, python3...)
 *   - Docker
 *   - kubectl + Minikube
 *   - Clone du repo FileZen
 */

pipeline {
    agent any

    environment {
        VM_HOST  = '192.168.12.161'
        VM_USER  = 'pfe'
        SSH_KEY  = '/var/jenkins_home/.ssh/filezen_vm'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        // ── STAGE 1 : Checkout ────────────────────────────────────────────────
        stage('🔄 Checkout') {
            steps {
                checkout scm
                echo "Pipeline Config — Build #${BUILD_NUMBER}"
            }
        }

        // ── STAGE 2 : Installer Ansible dans Jenkins ──────────────────────────
        stage('⚙️ Installer Ansible') {
            steps {
                sh """
                    echo "=== Installation Ansible ==="
                    if ! command -v ansible > /dev/null 2>&1; then
                        pip3 install --quiet --user --break-system-packages ansible 2>/dev/null \
                        || pip3 install --quiet --user ansible 2>/dev/null \
                        || pip install --quiet --user ansible 2>/dev/null \
                        || true
                    fi
                    export PATH="\$HOME/.local/bin:\$PATH"
                    ansible --version | head -1 || echo "Ansible non disponible"
                """
            }
        }

        // ── STAGE 3 : Test connectivité VM ───────────────────────────────────
        stage('🔌 Test Connectivité') {
            steps {
                sh """
                    chmod 600 ${SSH_KEY}
                    export PATH="\$HOME/.local/bin:\$PATH"
                    echo "=== Ping Ansible ==="
                    ansible -i ansible/inventory.ini filezen_vm -m ping \
                        || ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${VM_USER}@${VM_HOST} 'echo OK'
                """
            }
        }

        // ── STAGE 4 : Exécution Playbook Ansible ─────────────────────────────
        stage('🔧 Configuration Ansible') {
            steps {
                sh """
                    export PATH="\$HOME/.local/bin:\$PATH"
                    echo "=== Lancement du playbook ==="
                    ansible-playbook \
                        -i ansible/inventory.ini \
                        ansible/playbook.yml \
                        --diff \
                        -v \
                    || true
                """
            }
        }

        // ── STAGE 5 : Vérification post-config ───────────────────────────────
        stage('✅ Vérification') {
            steps {
                sh """
                    echo "=== Vérification de la configuration ==="
                    ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${VM_USER}@${VM_HOST} '
                        echo "--- Hostname ---"
                        hostname

                        echo "--- Docker ---"
                        docker --version

                        echo "--- kubectl ---"
                        kubectl version --client 2>/dev/null | head -1

                        echo "--- Minikube ---"
                        minikube version | head -1

                        echo "--- Nodes Kubernetes ---"
                        kubectl get nodes

                        echo "--- Repo FileZen ---"
                        ls /home/pfe/filezen/
                    '
                """
            }
        }
    }

    post {
        success {
            echo "Configuration VM terminee avec succes ! Build #${BUILD_NUMBER}"
        }
        failure {
            echo "Echec de la configuration — verifier les logs Ansible ci-dessus"
        }
    }
}
